{
  "expo": {
    "name": "Sendbook",
    "slug": "sendbook",
    "scheme": "sendbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sendbook.app"
    },
    "android": {
      "package": "com.sendbook.app",
      "versionCode": 1,
      "targetSdkVersion": 34,
      "usesCleartextTraffic": true,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-router",
      "expo-image-picker",
      "expo-file-system",
      [
        "expo-build-properties",
        {
          "android": { "networkInspector": false },
          "ios": { "networkInspector": false }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ec15b5b-cf0f-47f5-879f-f83f97d03ee8"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
